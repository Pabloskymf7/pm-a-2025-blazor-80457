@page "/movies"
@rendermode InteractiveServer

<PageTitle>Movies</PageTitle>

<h1>Movies</h1>

@if (movies.Count == 0) {
    <p><em>Loading Movies</em></p>
}
else {
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Genre</th>
                <th>Year</th>
                <th>Director</th>
                <th>Rating</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var movie in movies)
            {
                <tr>
                    <td><a class="movie-link" href="@($"/movies/{movie.Id}")">@movie.Title</a></td>
                    <td>@movie.Genre</td>
                    <td>@movie.ReleaseYear</td>
                    <td>@movie.Director</td>
                    <td>@movie.Rating.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<Model.Movie> movies = new();
    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(500);
        movies = Repository.MovieRepository.GetMovies();
    }
}
